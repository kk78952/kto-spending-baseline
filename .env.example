# Copy this file to config/trino.env and config/credentials.env, then fill in values.
# Never commit the actual .env files — they are gitignored.

# ── Trino connection (config/trino.env) ──────────────────────────────────────
TRINO_HOST=10.60.34.154
TRINO_PORT=8443
TRINO_CATALOG=hive
TRINO_SCHEMA=kto_658
TRINO_VERIFY_SSL=false

# ── Auth credentials (config/credentials.env) ────────────────────────────────
TRINO_USER=your_username
TRINO_PASSWORD=your_password

# ── Optional: Netlify deploy (for CI/CD push) ────────────────────────────────
NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=
